{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@tourbillon/db": ["./packages/db/src/index.ts"],
      "@tourbillon/shared": ["./packages/shared/src/index.ts"],
      "@tourbillon/mastra": ["./packages/mastra/src/index.ts"],
      "@tourbillon/scheduler": ["./packages/scheduler/src/index.ts"]
    }
  }
}
