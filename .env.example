# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paperclip_mastra

# LM Studio (local OpenAI-compatible API)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Default model loaded in LM Studio
LM_STUDIO_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Internal API (used by workers to call the Next.js API routes)
INTERNAL_API_URL=http://localhost:3000

# Optional: Tavily web search (cloud fallback)
# TAVILY_API_KEY=

# Optional: SearXNG local web search
# SEARXNG_URL=http://localhost:8888
